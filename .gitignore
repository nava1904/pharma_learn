# ===============================
# PharmaLearn LMS - .gitignore
# ===============================

# ===============================
# OS Generated Files
# ===============================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ===============================
# Editor & IDE
# ===============================

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# IntelliJ IDEA / Android Studio
*.iml
*.ipr
*.iws
.idea/
.idea/workspace.xml
.idea/tasks.xml
.idea/dictionaries
.idea/shelf
.idea/caches
.idea/*.iml

# Vim
*.swp
*.swo
*.swn
*~

# Emacs
*~
\#*\#
.#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# Atom
.atom/

# ===============================
# Dart / Flutter
# ===============================
.dart_tool/
.packages
.pub/
.pub-cache/
build/
pubspec.lock

# Flutter specific
.flutter-plugins
.flutter-plugins-dependencies
**/doc/api/
**/ios/Flutter/.last_build_id
migrate_working_dir/

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart
*.config.dart

# Coverage
coverage/
*.lcov

# Symbolication
app.*.symbols

# Obfuscation
app.*.map.json

# ===============================
# Environment & Secrets
# ===============================
.env
.env.*
.env.local
.env.development
.env.staging
.env.production
!.env.example
!.env.template

# API Keys & Secrets
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx

# Supabase
supabase/.branches/
supabase/.temp/
supabase/config.toml.local

# ===============================
# Database
# ===============================
*.db
*.sqlite
*.sqlite3
*.sql.bak
db_backups/
migrations/*.applied

# PostgreSQL
*.dump
*.pgdata

# ===============================
# Logs & Debug
# ===============================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
debug/
*.stacktrace

# ===============================
# Build & Compiled
# ===============================
build/
dist/
out/
*.class
*.dll
*.exe
*.o
*.so
*.pyc
__pycache__/

# ===============================
# Dependencies
# ===============================
node_modules/
.npm/
vendor/

# ===============================
# Testing
# ===============================
coverage/
.nyc_output/
*.lcov
test-results/
test-reports/
junit.xml

# ===============================
# Documentation Build
# ===============================
docs/_build/
docs/api/
site/

# ===============================
# Temporary Files
# ===============================
*.tmp
*.temp
*.bak
*.backup
*.old
.cache/
.temp/
tmp/
temp/

# ===============================
# Archives
# ===============================
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ===============================
# Mobile Platforms (if applicable)
# ===============================

# Android
/android/app/debug/
/android/app/profile/
/android/app/release/
*.apk
*.aab
*.jks
*.keystore
local.properties

# iOS
/ios/Pods/
/ios/.symlinks/
/ios/Flutter/Flutter.framework
/ios/Flutter/Flutter.podspec
/ios/Runner/GeneratedPluginRegistrant.*
*.ipa
*.dSYM.zip
*.dSYM

# ===============================
# CI/CD
# ===============================
.github/workflows/*.local.yml
.gitlab-ci-local/

# ===============================
# Docker (if applicable)
# ===============================
.docker/
docker-compose.override.yml

# ===============================
# Compliance & Audit (keep in repo)
# ===============================
# DO NOT ignore audit logs for 21 CFR Part 11 compliance
# !audit_logs/

# ===============================
# Project Specific
# ===============================
# Add project-specific ignores below
.buildlog/
.history
.svn/
.swiftpm/
